{
  "title": "LeetCode GraphQL Data Extractor Input",
  "type": "object",
  "schemaVersion": 1,
  "properties": {
    "operationName": {
      "title": "Operation to Execute",
      "type": "string",
      "description": "Select the specific LeetCode GraphQL operation you want to run.",
      "editor": "select",
      "enum": [
        "globalData",
        "checkin",
        "codingChallengeMedal",
        "trendingDiscuss",
        "getDidCompleteUpc",
        "upcomingContests",
        "studyPlanV2RecentCompletedProgress",
        "tabsStatus",
        "questionTitle",
        "premiumQuestion",
        "SimilarQuestions",
        "singleQuestionTopicTags",
        "userCanSeeQuestion",
        "consolePanelConfig",
        "questionEditorData",
        "languageList",
        "SurveyV2",
        "qdFeatureGuide",
        "annualReport",
        "questionContent",
        "qdChallengeQuestion",
        "learningContextName",
        "getStreakCounter",
        "currentTimestamp",
        "questionOfToday",
        "questionHints",
        "userQuestionStatus",
        "userQuestionLike",
        "userFavorites",
        "questionStats",
        "userQuestionAdminUrls",
        "questionCompanyStats",
        "discussionTopic",
        "syncedCode",
        "enableAiHelper",
        "debuggerLanguageFeatures",
        "editorialMeta",
        "hasOfficialSolution",
        "submissionList",
        "submissionFilterTypes",
        "questionNote",
        "solutionTags",
        "communitySolutions",
        "officialSolution",
        "learningContext",
        "randomPanelQuestion",
        "panelQuestionList",
        "updateSyncedCode",
        "questionSubmissionList",
        "submissionDetails",
        "communitySolution",
        "solutionArticleInformation",
        "prevNextSolution",
        "intentionTags",
        "questionDiscussComments",
        "siteAnnouncements",
        "GetProblemSetStudyPlanAds",
        "problemsetQuestionList",
        "GetMyStudyPlan",
        "dailyCodingQuestionRecords",
        "upcOnboardingStatus",
        "timeTravelTicketInfo",
        "userSessionProgress",
        "userPublicProfile",
        "languageStats",
        "skillStats",
        "userContestRankingInfo",
        "userProblemsSolved",
        "userBadges",
        "userProfileCalendar",
        "recentAcSubmissions",
        "getUserProfile",
        "userProgressQuestionList"
      ],
      "default": "questionTitle"
    },
    "username": {
      "title": "Username",
      "type": "string",
      "description": "The LeetCode username (required for user profile queries).",
      "editor": "textfield",
      "prefill": "user8162l"
    },
    "titleSlug": {
      "title": "Question Slug",
      "type": "string",
      "description": "The slug of the question (e.g. 'two-sum' or '3sum').",
      "editor": "textfield",
      "prefill": "two-sum"
    },
    "limit": {
      "title": "Limit",
      "type": "integer",
      "description": "Number of results to return (used for lists like submissions).",
      "editor": "number",
      "prefill": 20
    },
    "offset": {
      "title": "Offset",
      "type": "integer",
      "description": "Starting index for pagination.",
      "editor": "number",
      "prefill": 0
    },
    "customVariables": {
      "title": "Custom Variables (JSON)",
      "type": "object",
      "description": "Any additional variables needed by the selected query in JSON format (e.g. {\"year\": 2023, \"month\": 7}).",
      "editor": "json",
      "prefill": {}
    },
    "endpoint": {
      "title": "GraphQL endpoint URL",
      "type": "string",
      "description": "LeetCode GraphQL endpoint.",
      "editor": "textfield",
      "prefill": "https://leetcode.com/graphql/"
    },
    "headers": {
      "title": "Custom headers (JSON object)",
      "type": "object",
      "description": "Optional headers (like Cookie, x-csrftoken) needed for private mutations.",
      "editor": "json",
      "prefill": {}
    }
  },
  "required": [
    "operationName"
  ]
}
